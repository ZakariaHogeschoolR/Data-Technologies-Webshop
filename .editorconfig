root = true

[*]
indent_style = space
indent_size = 4
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

[*.cs]
# OOP NAMING CONVENTIONS
#Interfaces moeten met een I beginnen
dotnet_naming_rule.interface_should_begun_with_i.severity = warning
dotnet_naming_rule.interface_should_begun_with_i.symbols = interface
dotnet_naming_rule.interface_should_begun_with_i.style = begun_with_i

dotnet_naming_symbols.interface.applicable_kinds = interface
dotnet_naming_symbols.interface.applicable_accessibilities = *

dotnet_naming_style.begun_with_i.required_prefix = I
dotnet_naming_style.begun_with_i.capitalization = pascal_case

#Gebruik File-scoped namespaces
csharp_style_namespace_declarations = file_scoped:warning

#OOP Toegankelijkheid
#Geef expliciet de accesibility modifiers aan (bijv. 'private')
dotnet_style_require_accesibility_modifiers = always:suggestion

#Organisatie van "using's"
dotnet_separate_import_directive_groups = true
dotnet_sort_system_directives_first = true

# C# zoals geleerd
csharp_style_expression_bodied_methods = true:suggestion
csharp_style_expression_bodied_properties = true:suggestion